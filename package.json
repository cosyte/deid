{
  "name": "@cosyte/deid",
  "version": "0.0.1",
  "description": "Healthcare de-identification for Node.js and TypeScript — a HIPAA Safe Harbor policy engine that fails closed and emits a value-free manifest.",
  "keywords": [
    "deid",
    "de-identification",
    "hipaa",
    "safe-harbor",
    "phi",
    "healthcare",
    "interoperability",
    "typescript"
  ],
  "homepage": "https://github.com/cosyte/deid#readme",
  "bugs": {
    "url": "https://github.com/cosyte/deid/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosyte/deid.git"
  },
  "license": "MIT",
  "author": "Cosyte <hello@cosyte.com> (https://cosyte.com)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "js-yaml@>=4.0.0 <4.2.0": "4.2.0"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hl7": {
      "import": {
        "types": "./dist/hl7/index.d.ts",
        "default": "./dist/hl7/index.mjs"
      },
      "require": {
        "types": "./dist/hl7/index.d.cts",
        "default": "./dist/hl7/index.cjs"
      }
    },
    "./ccda": {
      "import": {
        "types": "./dist/ccda/index.d.ts",
        "default": "./dist/ccda/index.mjs"
      },
      "require": {
        "types": "./dist/ccda/index.d.cts",
        "default": "./dist/ccda/index.cjs"
      }
    },
    "./fhir": {
      "import": {
        "types": "./dist/fhir/index.d.ts",
        "default": "./dist/fhir/index.mjs"
      },
      "require": {
        "types": "./dist/fhir/index.d.cts",
        "default": "./dist/fhir/index.cjs"
      }
    },
    "./x12": {
      "import": {
        "types": "./dist/x12/index.d.ts",
        "default": "./dist/x12/index.mjs"
      },
      "require": {
        "types": "./dist/x12/index.d.cts",
        "default": "./dist/x12/index.cjs"
      }
    },
    "./ncpdp": {
      "import": {
        "types": "./dist/ncpdp/index.d.ts",
        "default": "./dist/ncpdp/index.mjs"
      },
      "require": {
        "types": "./dist/ncpdp/index.d.cts",
        "default": "./dist/ncpdp/index.cjs"
      }
    },
    "./dicom": {
      "import": {
        "types": "./dist/dicom/index.d.ts",
        "default": "./dist/dicom/index.mjs"
      },
      "require": {
        "types": "./dist/dicom/index.d.cts",
        "default": "./dist/dicom/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@cosyte/hl7": ">=0.0.0",
    "@cosyte/ccda": ">=0.0.0",
    "@cosyte/fhir": ">=0.0.0",
    "@cosyte/x12": ">=0.0.0",
    "@cosyte/ncpdp": ">=0.0.0",
    "@cosyte/dicom": ">=0.0.0"
  },
  "peerDependenciesMeta": {
    "@cosyte/hl7": {
      "optional": true
    },
    "@cosyte/ccda": {
      "optional": true
    },
    "@cosyte/fhir": {
      "optional": true
    },
    "@cosyte/x12": {
      "optional": true
    },
    "@cosyte/ncpdp": {
      "optional": true
    },
    "@cosyte/dicom": {
      "optional": true
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prettier": "@cosyte/prettier-config",
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "typecheck": "tsc --noEmit",
    "phi-scan": "tsx scripts/phi-scan.ts",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"test/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.{json,md,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,md}\" \"test/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.{json,md,yml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage",
    "pack:docs": "bash scripts/build-docs-artifacts.sh",
    "smoke": "node scripts/smoke.mjs",
    "attw": "attw --pack . --profile node16",
    "version": "changeset version && prettier --write package.json CHANGELOG.md",
    "release": "changeset publish",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm attw",
    "prepare": "command -v simple-git-hooks >/dev/null 2>&1 && simple-git-hooks || true"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm phi-scan --staged"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@changesets/cli": "2.31.0",
    "@cosyte/ccda": "file:vendor/cosyte-ccda-0.0.1.tgz",
    "@cosyte/dicom": "file:vendor/cosyte-dicom-0.0.1.tgz",
    "@cosyte/eslint-config": "^0.0.4",
    "@cosyte/fhir": "file:vendor/cosyte-fhir-0.0.0.tgz",
    "@cosyte/hl7": "file:vendor/cosyte-hl7-0.0.1.tgz",
    "@cosyte/ncpdp": "file:vendor/cosyte-ncpdp-0.0.1.tgz",
    "@cosyte/prettier-config": "^0.0.2",
    "@cosyte/test-utils": "^0.0.1",
    "@cosyte/tsconfig": "^0.0.2",
    "@cosyte/tsup-config": "^0.0.1",
    "@cosyte/vitest-config": "^0.0.2",
    "@cosyte/x12": "file:vendor/cosyte-x12-0.0.1.tgz",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "@xmldom/xmldom": "0.9.10",
    "eslint": "10.5.0",
    "fast-check": "3.23.2",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.4"
  },
  "dependencies": {}
}
